DATABASE_URL=postgresql+psycopg2://ticketmaster:ticketmaster@pgbouncer:6432/ticketmaster
POSTGRES_DB=ticketmaster
POSTGRES_USER=ticketmaster
POSTGRES_PASSWORD=ticketmaster
APP_SECRET=dev-ticketmaster-secret-change-me
APP_BASE_URL=http://localhost:3006
TICKETMASTER_DEV_PASSWORD=ChangeMe123!

SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=ticketmaster@example.test
SMTP_TLS=false
MAIL_SUPPRESS_SEND=false

GITLAB_BASE_URL=https://gitlab.example.test
GITLAB_PROJECT_ID=ticketmaster-dev-placeholder
GITLAB_TOKEN=
GITLAB_DRY_RUN=true

UPLOAD_DIR=/app/uploads

CORS_ORIGINS=*
TRUSTED_HOSTS=*
LOGIN_RATE_LIMIT_ATTEMPTS=10
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
TICKET_PAGE_DEFAULT_LIMIT=50
TICKET_PAGE_MAX_LIMIT=200
WEB_CONCURRENCY=2

REDIS_URL=redis://redis:6379/0
QUEUE_ENABLED=true
QUEUE_NAME=ticketmaster:jobs
QUEUE_POLL_TIMEOUT_SECONDS=5
WORKER_RETRY_INTERVAL_SECONDS=30

SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.05

ELASTICSEARCH_ENABLED=true
ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_INDEX=ticketmaster-tickets
ES_JAVA_OPTS=-Xms512m -Xmx512m

CLAMAV_ENABLED=true
CLAMAV_HOST=clamav
CLAMAV_PORT=3310
CLAMAV_TIMEOUT_SECONDS=30

PGBOUNCER_MAX_CLIENT_CONN=500
PGBOUNCER_DEFAULT_POOL_SIZE=25
PGBOUNCER_RESERVE_POOL_SIZE=5

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
